# Koneksi SSH yang sudah dapat dipakai tanpa password interaktif.
VPS_SSH=nama-user@IP_VPS
VPS_SSH_PORT=22

# Untuk aplikasi server yang dijalankan di container VPS.
APP_PORT=3000
LOCAL_PORT=3000

# Opsional. Jika kosong, dipilih otomatis dan hanya bind ke 127.0.0.1 VPS.
# REMOTE_PORT=49152

# sccache
SCCACHE_CACHE_SIZE=7G